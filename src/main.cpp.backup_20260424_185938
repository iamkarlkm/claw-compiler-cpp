// Claw Compiler - Main Entry Point v0.4
// Architecture: Lexer → Parser → (AST Interpreter | Bytecode Pipeline)
// Note: Bytecode/VM/JIT modules require API fixes

#include <iostream>
#include <fstream>
#include <sstream>
#include <string>
#include <vector>
#include <memory>
#include <chrono>
#include <cstring>
#include <algorithm>
#include "lexer/lexer.h"
#include "lexer/token.h"
#include "parser/parser.h"
#include "common/common.h"
#include "interpreter/interpreter.h"

using namespace claw;

// ============================================================================
// 配置与常量
// ============================================================================

namespace config {
    static const std::string VERSION = "0.4";
    static const std::string DEFAULT_MODE = "ast";
    static const std::vector<std::string> MODES = {"ast", "bytecode", "jit", "hybrid"};
}

// ============================================================================
// 执行模式枚举
// ============================================================================

enum class ExecutionMode {
    AST_INTERPRETER,  // AST 解释器 (当前唯一工作模式)
    BYTECODE_VM,      // 字节码虚拟机 (API 不兼容)
    JIT_COMPILER,     // JIT 编译执行 (API 不兼容)
    HYBRID            // 混合模式 (JIT + VM, API 不兼容)
};

// ============================================================================
// 编译器状态
// ============================================================================

struct CompilerState {
    std::string filename;
    std::string source;
    std::vector<Token> tokens;
    std::unique_ptr<ast::Program> program;
    ExecutionMode mode = ExecutionMode::AST_INTERPRETER;
    bool print_tokens = false;
    bool print_ast = false;
    bool verbose = false;
    bool print_stats = false;
};

// ============================================================================
// 工具函数
// ============================================================================

static void print_banner() {
    std::cout << "==============================================\n";
    std::cout << "   Claw Compiler v" << config::VERSION << " (AST Mode)\n";
    std::cout << "==============================================\n\n";
}

static void print_usage(const char* prog) {
    std::cout << "Claw Compiler v" << config::VERSION << "\n";
    std::cout << "Usage: " << prog << " [options] <file>\n\n";
    std::cout << "Options:\n";
    std::cout << "  -m, --mode=<mode>    Execution mode: ast|bytecode|jit|hybrid (default: ast)\n";
    std::cout << "  -t, --tokens         Print tokens after lexing\n";
    std::cout << "  -a, --ast            Print AST after parsing\n";
    std::cout << "  -v, --verbose        Verbose output\n";
    std::cout << "  -s, --stats          Print execution statistics\n";
    std::cout << "  -h, --help           Show this help\n";
    std::cout << "\nExecution Modes:\n";
    std::cout << "  ast       - AST interpreter (working)\n";
    std::cout << "  bytecode  - Bytecode VM (coming soon)\n";
    std::cout << "  jit       - JIT compiler (coming soon)\n";
    std::cout << "  hybrid    - Hybrid mode (coming soon)\n";
}

static ExecutionMode parse_mode(const std::string& mode_str) {
    if (mode_str == "ast") return ExecutionMode::AST_INTERPRETER;
    if (mode_str == "bytecode") {
        std::cout << "Note: Bytecode mode not yet available, using AST mode\n";
        return ExecutionMode::AST_INTERPRETER;
    }
    if (mode_str == "jit") {
        std::cout << "Note: JIT mode not yet available, using AST mode\n";
        return ExecutionMode::AST_INTERPRETER;
    }
    if (mode_str == "hybrid") {
        std::cout << "Note: Hybrid mode not yet available, using AST mode\n";
        return ExecutionMode::AST_INTERPRETER;
    }
    std::cerr << "Warning: Unknown mode '" << mode_str << "', using 'ast'\n";
    return ExecutionMode::AST_INTERPRETER;
}

static std::string mode_to_string(ExecutionMode mode) {
    switch (mode) {
        case ExecutionMode::AST_INTERPRETER: return "AST Interpreter";
        case ExecutionMode::BYTECODE_VM: return "Bytecode VM";
        case ExecutionMode::JIT_COMPILER: return "JIT Compiler";
        case ExecutionMode::HYBRID: return "Hybrid (JIT + VM)";
    }
    return "Unknown";
}

// ============================================================================
// 词法分析阶段
// ============================================================================

static bool lex_source(CompilerState& state) {
    if (state.verbose) std::cout << "[1/3] Lexing...\n";
    
    Lexer lexer(state.source, state.filename);
    state.tokens = lexer.scan_all();
    
    if (state.verbose) std::cout << "  - Lexed " << state.tokens.size() << " tokens\n";
    
    if (state.print_tokens) {
        std::cout << "\n=== Tokens ===\n";
        for (const auto& tok : state.tokens) {
            std::cout << token_type_to_string(tok.type) << ": " << tok.lexeme() << "\n";
        }
        return true;
    }
    return false;
}

// ============================================================================
// 语法分析阶段
// ============================================================================

static bool parse_source(CompilerState& state) {
    if (state.verbose) std::cout << "[2/3] Parsing...\n";
    
    Parser parser(state.tokens);
    parser.set_reporter(nullptr);
    state.program = parser.parse();
    
    if (!state.program) {
        std::cerr << "Error: Parsing failed\n";
        return false;
    }
    
    if (state.verbose) std::cout << "  - Parsed successfully\n";
    
    if (state.print_ast) {
        std::cout << "\n=== AST ===\n";
        std::cout << state.program->to_string() << "\n";
        return true;
    }
    return false;
}

// ============================================================================
// AST 解释器执行
// ============================================================================

static int execute_ast(CompilerState& state) {
    if (state.verbose) std::cout << "\n[3/3] Executing with AST interpreter...\n";
    
    auto start_time = std::chrono::high_resolution_clock::now();
    
    claw::interpreter::Interpreter interp;
    interp.execute(state.program.get());
    
    auto end_time = std::chrono::high_resolution_clock::now();
    auto duration = std::chrono::duration_cast<std::chrono::microseconds>(end_time - start_time);
    
    if (state.print_stats || state.verbose) {
        std::cout << "\n==============================================\n";
        std::cout << "               Statistics\n";
        std::cout << "==============================================\n";
        std::cout << "Mode:            AST Interpretation\n";
        std::cout << "Execution Time:  " << duration.count() / 1000.0 << " ms\n";
        std::cout << "Tokens:          " << state.tokens.size() << "\n";
        std::cout << "Source Size:     " << state.source.size() << " bytes\n";
        std::cout << "Lines:           " << std::count(state.source.begin(), state.source.end(), '\n') + 1 << "\n";
    }
    
    return 0;
}

// ============================================================================
// 参数解析
// ============================================================================

static bool parse_arguments(int argc, char* argv[], CompilerState& state) {
    for (int i = 1; i < argc; i++) {
        std::string arg = argv[i];
        
        if (arg == "-h" || arg == "--help") {
            print_usage(argv[0]);
            return false;
        }
        else if (arg == "-t" || arg == "--tokens") {
            state.print_tokens = true;
        }
        else if (arg == "-a" || arg == "--ast") {
            state.print_ast = true;
        }
        else if (arg == "-v" || arg == "--verbose") {
            state.verbose = true;
        }
        else if (arg == "-s" || arg == "--stats") {
            state.print_stats = true;
        }
        else if (arg.rfind("-m=", 0) == 0 || arg.rfind("--mode=", 0) == 0) {
            std::string mode = arg.substr(arg.find('=') + 1);
            state.mode = parse_mode(mode);
        }
        else if (arg[0] != '-') {
            state.filename = arg;
        }
    }
    
    return true;
}

// ============================================================================
// 主函数
// ============================================================================

int main(int argc, char* argv[]) {
    print_banner();
    
    CompilerState state;
    
    // 解析参数
    if (!parse_arguments(argc, argv, state)) {
        return 0;
    }
    
    // 验证输入文件
    if (state.filename.empty()) {
        std::cerr << "Error: No input file specified\n";
        print_usage(argv[0]);
        return 1;
    }
    
    if (state.verbose) {
        std::cout << "Input file: " << state.filename << "\n";
        std::cout << "Execution mode: " << mode_to_string(state.mode) << "\n\n";
    }
    
    // 读取源文件
    if (state.verbose) std::cout << "[0/3] Reading source...\n";
    
    std::ifstream file(state.filename);
    if (!file.is_open()) {
        std::cerr << "Error: Cannot open file: " << state.filename << "\n";
        return 1;
    }
    
    std::stringstream buffer;
    buffer << file.rdbuf();
    state.source = buffer.str();
    file.close();
    
    if (state.verbose) std::cout << "  - Loaded " << state.source.size() << " bytes\n";
    
    // 阶段 1: 词法分析
    if (lex_source(state)) {
        return 0;
    }
    
    // 阶段 2: 语法分析
    if (parse_source(state)) {
        return 0;
    }
    
    // 阶段 3: 执行
    int result = execute_ast(state);
    
    if (state.verbose) {
        std::cout << "\n[Done] Compilation complete\n";
    }
    
    return result;
}
