#include "bytecode_compiler.h"
#include <cstdarg>
#include <algorithm>
#include <iostream>

namespace claw {

// ========== 构造函数 ==========

BytecodeCompiler::BytecodeCompiler() 
    : module_(std::make_shared<bytecode::Module>()) {
    ctx_ = std::make_unique<CompilationContext>();
    // Initialize global scope
    ctx_->scopeStack.push_back({});
}

BytecodeCompiler::~BytecodeCompiler() = default;

// ========== 主编译入口 ==========

std::shared_ptr<bytecode::Module> BytecodeCompiler::compile(const ast::Program& program) {
    try {
        compileModule(program);
        return module_;
    } catch (const std::exception& e) {
        lastError_ = e.what();
        return nullptr;
    }
}

// ========== 程序编译 ==========

void BytecodeCompiler::compileModule(const ast::Program& program) {
    module_->name = "main";
    
    // 编译所有函数定义
    for (const auto& stmt : program.get_declarations()) {
        auto kind = stmt->get_kind();
        if (kind == ast::Statement::Kind::Function) {
            // 使用 dynamic_cast 进行安全的类型转换
            const auto* funcStmt = dynamic_cast<const ast::FunctionStmt*>(stmt.get());
            if (funcStmt) {
                compileFunction(*funcStmt);
            }
        } else if (kind == ast::Statement::Kind::Let) {
            // 全局 let 声明
            const auto* letStmt = dynamic_cast<const ast::LetStmt*>(stmt.get());
            if (letStmt) {
                compileLetStmt(*letStmt);
            }
        }
    }
    
    // 编译主语句块 (非函数定义)
    for (const auto& stmt : program.get_declarations()) {
        if (stmt->get_kind() != ast::Statement::Kind::Function) {
            compileStatement(*stmt);
        }
    }
    
    // 添加 HALT 指令
    emitOp(bytecode::OpCode::HALT);
}

void BytecodeCompiler::compileFunction(const ast::FunctionStmt& func) {
    // 创建新函数 (值类型)
    bytecode::Function byteFunc;
    byteFunc.name = func.get_name();
    byteFunc.arity = static_cast<uint32_t>(func.get_params().size());
    byteFunc.local_count = static_cast<uint32_t>(func.get_params().size());
    
    // 保存旧上下文并创建新的
    auto prevCtx = std::move(ctx_);
    ctx_ = std::make_unique<CompilationContext>();
    ctx_->currentFunction = &byteFunc;
    ctx_->isClosure = false;
    ctx_->scopeStack.push_back({});
    
    // 记录返回值类型 (使用 type_info)
    if (!func.get_return_type().empty()) {
        byteFunc.local_names.push_back(func.get_return_type()); // 借用 local_names[0] 存储返回类型
    }

    // 分配参数槽位
    int slot = 0;
    for (const auto& param : func.get_params()) {
        ctx_->scopeStack.back()[param.first] = slot++;
        byteFunc.local_names.push_back(param.first);
    }
    
    // 编译函数体
    enterScope();
    if (func.get_body()) {
        // Determine body type and compile accordingly
        if (auto* block = dynamic_cast<const ast::BlockStmt*>(func.get_body())) {
            compileBlockStmt(*block);
        } else if (auto* expr = dynamic_cast<const ast::Expression*>(func.get_body())) {
            // Single expression as function body - wrap in implicit return
            compileExpression(*expr);
            emitOp(bytecode::OpCode::RET);
        }
    }
    exitScope();
    
    // 如果没有显式返回，添加 null 返回
    if (ctx_->currentFunction->code.empty() ||
        ctx_->currentFunction->code.back().op != bytecode::OpCode::RET) {
        emitOp(bytecode::OpCode::RET_NULL);
    }
    
    // 更新 upvalue 数量
    byteFunc.upvalues.resize(ctx_->upvalues.size());
    
    // 添加到模块
    module_->functions.push_back(byteFunc);
    
    // 恢复旧上下文
    ctx_ = std::move(prevCtx);
}

// ========== 语句编译 ==========

void BytecodeCompiler::compileStatement(const ast::Statement& stmt) {
    switch (stmt.get_kind()) {
        case ast::Statement::Kind::Let:
            compileLetStmt(static_cast<const ast::LetStmt&>(stmt));
            break;
        case ast::Statement::Kind::Assign:
            compileAssignStmt(static_cast<const ast::AssignStmt&>(stmt));
            break;
        case ast::Statement::Kind::If:
            compileIfStmt(static_cast<const ast::IfStmt&>(stmt));
            break;
        case ast::Statement::Kind::Match:
            compileMatchStmt(static_cast<const ast::MatchStmt&>(stmt));
            break;
        case ast::Statement::Kind::For:
            compileForStmt(static_cast<const ast::ForStmt&>(stmt));
            break;
        case ast::Statement::Kind::While:
            compileWhileStmt(static_cast<const ast::WhileStmt&>(stmt));
            break;
        case ast::Statement::Kind::Loop:
            compileLoopStmt(static_cast<const ast::WhileStmt&>(stmt));  // Loop = While(true)
            break;
        case ast::Statement::Kind::Return:
            compileReturnStmt(static_cast<const ast::ReturnStmt&>(stmt));
            break;
        case ast::Statement::Kind::Break:
            compileBreakStmt(static_cast<const ast::BreakStmt&>(stmt));
            break;
        case ast::Statement::Kind::Continue:
            compileContinueStmt(static_cast<const ast::ContinueStmt&>(stmt));
            break;
        case ast::Statement::Kind::Block:
            compileBlockStmt(static_cast<const ast::BlockStmt&>(stmt));
            break;
        case ast::Statement::Kind::Expression:
            compileExprStmt(static_cast<const ast::ExprStmt&>(stmt));
            break;
        case ast::Statement::Kind::Publish:
            compilePublishStmt(static_cast<const ast::PublishStmt&>(stmt));
            break;
        case ast::Statement::Kind::Subscribe:
            compileSubscribeStmt(static_cast<const ast::SubscribeStmt&>(stmt));
            break;
        default:
            errorf("Unsupported statement kind: %d", (int)stmt.get_kind());
    }
}

void BytecodeCompiler::compileLetStmt(const ast::LetStmt& stmt) {
    // 编译右侧表达式
    if (stmt.get_initializer()) {
        compileExpression(*stmt.get_initializer());
    } else {
        emitOp(bytecode::OpCode::PUSH);
        emitOp1(bytecode::OpCode::PUSH, 0); // null
    }
    
    // 分配局部变量
    int slot = allocateLocal(stmt.get_name());
    
    // 如果是全局作用域，生成全局变量定义
    if (ctx_->scopeStack.size() == 1) {
        int globalSlot = nextGlobalSlot_++;
        globalVars_[stmt.get_name()] = globalSlot;
        emitOp1(bytecode::OpCode::DEFINE_GLOBAL, findOrAddString(stmt.get_name()));
        emitOp(bytecode::OpCode::STORE_GLOBAL);
    } else {
        emitOp(bytecode::OpCode::STORE_LOCAL);
        emitOp1(bytecode::OpCode::STORE_LOCAL, slot);
    }
}

void BytecodeCompiler::compileAssignStmt(const ast::AssignStmt& stmt) {
    compileExpression(*stmt.get_value());
    
    // 解析目标变量
    auto* target = stmt.get_target();
    if (auto* ident = dynamic_cast<const ast::IdentifierExpr*>(target)) {
        int slot = resolveVariable(ident->get_name());
        if (slot >= 0) {
            emitOp1(bytecode::OpCode::STORE_LOCAL, slot);
        } else {
            auto it = globalVars_.find(ident->get_name());
            if (it != globalVars_.end()) {
                emitOp1(bytecode::OpCode::STORE_GLOBAL, it->second);
            } else {
                error("Unknown variable: " + ident->get_name());
            }
        }
    } else {
        // 索引赋值或字段赋值
        compileExpression(*target);
        emitOp(bytecode::OpCode::STORE_INDEX);
    }
}

void BytecodeCompiler::compileIfStmt(const ast::IfStmt& stmt) {
    std::vector<int> endJumpIdxs;
    
    const auto& conditions = stmt.get_conditions();
    const auto& bodies = stmt.get_bodies();
    
    for (size_t i = 0; i < conditions.size(); ++i) {
        // 编译条件
        if (conditions[i]) {
            compileExpression(*conditions[i]);
        } else {
            // else 分支，条件为 true
            emitOp(bytecode::OpCode::PUSH);
            emitOp1(bytecode::OpCode::PUSH, 1);
        }
        
        // 跳转到下一个条件或 else 分支 (如果条件为 false)
        int nextJumpIdx = ctx_->currentFunction->code.size();
        emitOp(bytecode::OpCode::JMP_IF_NOT);
        ctx_->pendingJumps.push_back({nextJumpIdx, 0, true});
        
        // 编译 then 分支
        if (bodies[i]) {
            enterScope();
            if (auto* block = dynamic_cast<const ast::BlockStmt*>(bodies[i])) {
                compileBlockStmt(*block);
            } else if (auto* expr = dynamic_cast<const ast::Expression*>(bodies[i])) {
                compileExpression(*expr);
                emitOp(bytecode::OpCode::POP); // 表达式结果需要 pop
            }
            exitScope();
        }
        
        // 跳到 if 结束处
        int afterThenIdx = ctx_->currentFunction->code.size();
        emitOp(bytecode::OpCode::JMP);
        endJumpIdxs.push_back(ctx_->currentFunction->code.size() - 1);
        ctx_->pendingJumps.push_back({afterThenIdx, 0, true});
        
        // 回填当前条件跳转目标 (跳到下一个条件或 else)
        patchJump(nextJumpIdx, ctx_->currentFunction->code.size());
    }
    
    // 编译 else 分支
    if (stmt.get_else_body()) {
        enterScope();
        if (auto* block = dynamic_cast<const ast::BlockStmt*>(stmt.get_else_body())) {
            compileBlockStmt(*block);
        } else if (auto* expr = dynamic_cast<const ast::Expression*>(stmt.get_else_body())) {
            compileExpression(*expr);
            emitOp(bytecode::OpCode::POP);
        }
        exitScope();
    }
    
    // 回填所有结束跳转
    for (size_t i = 0; i < endJumpIdxs.size(); ++i) {
        patchJump(endJumpIdxs[i], ctx_->currentFunction->code.size());
    }
}

void BytecodeCompiler::compileMatchStmt(const ast::MatchStmt& stmt) {
    // 编译被匹配的值
    compileExpression(*stmt.get_expr());
    
    // 为每个 case 生成跳转
    std::vector<int> caseEndIdxs;
    int defaultCaseIdx = -1;
    
    for (size_t i = 0; i < stmt.get_cases().size(); ++i) {
        const auto& matchCase = stmt.get_cases()[i];
        
        if (matchCase.pattern == "_") {
            // 默认 case
            defaultCaseIdx = i;
            continue;
        }
        
        // 复制要匹配的值到栈顶
        emitOp(bytecode::OpCode::DUP);
        
        // 编译模式并比较
        if (matchCase.pattern == "true" || matchCase.pattern == "false") {
            emitConst(matchCase.pattern == "true" ? 1 : 0);
            emitOp(bytecode::OpCode::IEQ);
        } else {
            // 尝试解析为整数
            try {
                int intVal = std::stoi(matchCase.pattern);
                emitConst(intVal);
                emitOp(bytecode::OpCode::IEQ);
            } catch (...) {
                // 字符串比较
                emitConst(matchCase.pattern);
                emitOp(bytecode::OpCode::IEQ);
            }
        }
        
        // 如果匹配，跳转到对应 case
        int caseJumpIdx = ctx_->currentFunction->instructions.size();
        emitOp(bytecode::OpCode::JMP_IF);
        ctx_->pendingJumps.push_back({caseJumpIdx, 0, true});
        
        // 编译 case 体
        enterScope();
        compileBlockStmt(matchCase.body);
        exitScope();
        
        // 跳到 match 结束
        int endJumpIdx = ctx_->currentFunction->instructions.size();
        emitOp(bytecode::OpCode::JMP);
        caseEndIdxs.push_back(ctx_->currentFunction->instructions.size() - 1);
        ctx_->pendingJumps.push_back({endJumpIdx, 0, true});
        
        // 回填 case 跳转
        patchJump(caseJumpIdx, ctx_->currentFunction->instructions.size());
    }
    
    // 回填所有 case 结束跳转
    for (int idx : caseEndIdxs) {
        patchJump(idx, ctx_->currentFunction->instructions.size());
    }
}

void BytecodeCompiler::compileForStmt(const ast::ForStmt& stmt) {
    // for i in range(0, 10) { ... }
    // 编译初始化
    if (stmt.get_init()) {
        compileExpression(*stmt.get_init());
    }
    
    // 循环开始位置
    int loopStartIdx = ctx_->currentFunction->instructions.size();
    
    // 保存循环上下文
    LoopContext loopCtx;
    loopCtx.breakJumpIdx = -1;
    loopCtx.continueJumpIdx = -1;
    loopCtx.scopeDepth = ctx_->scopeDepth;
    ctx_->loopStack.push_back(loopCtx);
    
    // 编译条件
    if (stmt.get_condition()) {
        compileExpression(*stmt.get_condition());
        int condJumpIdx = ctx_->currentFunction->instructions.size();
        emitOp(bytecode::OpCode::JMP_IF_NOT);
        ctx_->pendingJumps.push_back({condJumpIdx, 0, true});
        patchJump(condJumpIdx, ctx_->currentFunction->instructions.size());
    }
    
    // 编译循环体
    enterScope();
    // 为迭代变量分配槽位
    if (!stmt.get_iter_var().empty()) {
        allocateLocal(stmt.get_iter_var());
    }
    compileBlockStmt(stmt.get_body());
    exitScope();
    
    // 编译迭代表达式
    if (stmt.get_increment()) {
        compileExpression(*stmt.get_increment());
        emitOp(bytecode::OpCode::POP); // 丢弃迭代结果
    }
    
    // 跳回循环开始
    emitOp1(bytecode::OpCode::JMP, loopStartIdx);
    
    // 回填 break 跳转
    if (!ctx_->loopStack.empty() && ctx_->loopStack.back().breakJumpIdx >= 0) {
        patchJump(ctx_->loopStack.back().breakJumpIdx, 
                  ctx_->currentFunction->instructions.size());
    }
    
    ctx_->loopStack.pop_back();
}

void BytecodeCompiler::compileWhileStmt(const ast::WhileStmt& stmt) {
    int loopStartIdx = ctx_->currentFunction->instructions.size();
    
    // 保存循环上下文
    LoopContext loopCtx;
    loopCtx.breakJumpIdx = -1;
    loopCtx.continueJumpIdx = -1;
    loopCtx.scopeDepth = ctx_->scopeDepth;
    ctx_->loopStack.push_back(loopCtx);
    
    // 编译条件
    compileExpression(*stmt.get_condition());
    int condJumpIdx = ctx_->currentFunction->instructions.size();
    emitOp(bytecode::OpCode::JMP_IF_NOT);
    ctx_->pendingJumps.push_back({condJumpIdx, 0, true});
    patchJump(condJumpIdx, ctx_->currentFunction->instructions.size());
    
    // 编译循环体
    enterScope();
    compileBlockStmt(stmt.get_body());
    exitScope();
    
    // 跳回循环开始
    emitOp1(bytecode::OpCode::JMP, loopStartIdx);
    
    // 回填 break 跳转
    if (!ctx_->loopStack.empty() && ctx_->loopStack.back().breakJumpIdx >= 0) {
        patchJump(ctx_->loopStack.back().breakJumpIdx,
                  ctx_->currentFunction->instructions.size());
    }
    
    ctx_->loopStack.pop_back();
}

void BytecodeCompiler::compileLoopStmt(const ast::LoopStmt& stmt) {
    int loopStartIdx = ctx_->currentFunction->instructions.size();
    
    // 保存循环上下文
    LoopContext loopCtx;
    loopCtx.breakJumpIdx = -1;
    loopCtx.continueJumpIdx = -1;
    loopCtx.scopeDepth = ctx_->scopeDepth;
    ctx_->loopStack.push_back(loopCtx);
    
    // 编译循环体
    enterScope();
    compileBlockStmt(stmt.get_body());
    exitScope();
    
    // 无条件跳回循环开始
    emitOp1(bytecode::OpCode::JMP, loopStartIdx);
    
    // 回填 break 跳转
    if (!ctx_->loopStack.empty() && ctx_->loopStack.back().breakJumpIdx >= 0) {
        patchJump(ctx_->loopStack.back().breakJumpIdx,
                  ctx_->currentFunction->instructions.size());
    }
    
    ctx_->loopStack.pop_back();
}

void BytecodeCompiler::compileReturnStmt(const ast::ReturnStmt& stmt) {
    if (stmt.get_value()) {
        compileExpression(*stmt.get_value());
    } else {
        emitOp(bytecode::OpCode::PUSH);
        emitOp1(bytecode::OpCode::PUSH, 0); // null
    }
    emitOp(bytecode::OpCode::RET);
}

void BytecodeCompiler::compileBreakStmt(const ast::BreakStmt& stmt) {
    if (ctx_->loopStack.empty()) {
        error("break outside of loop");
        return;
    }
    
    int jumpIdx = ctx_->currentFunction->instructions.size();
    emitOp(bytecode::OpCode::JMP);
    
    // 记录待回填的 break 跳转
    ctx_->loopStack.back().breakJumpIdx = jumpIdx;
    ctx_->pendingJumps.push_back({jumpIdx, 0, true});
}

void BytecodeCompiler::compileContinueStmt(const ast::ContinueStmt& stmt) {
    if (ctx_->loopStack.empty()) {
        error("continue outside of loop");
        return;
    }
    
    // 找到最近的循环开始位置
    int loopStartIdx = -1;
    for (auto it = ctx_->loopStack.rbegin(); it != ctx_->loopStack.rend(); ++it) {
        // 需要在正确的作用域中查找
        // 这里简化处理，直接跳转到最后一条指令位置
        break;
    }
    
    // 简化的 continue 实现：跳转到当前函数的最后
    // 实际的实现需要追踪 continue 目标
    emitOp(bytecode::OpCode::JMP);
    int jumpIdx = ctx_->currentFunction->instructions.size() - 1;
    ctx_->loopStack.back().continueJumpIdx = jumpIdx;
}

void BytecodeCompiler::compileBlockStmt(const ast::BlockStmt& block) {
    for (const auto& stmt : block.get_statements()) {
        compileStatement(*stmt);
    }
}

void BytecodeCompiler::compileExprStmt(const ast::ExprStmt& stmt) {
    compileExpression(*stmt.get_expr());
    emitOp(bytecode::OpCode::POP); // 丢弃表达式结果
}

void BytecodeCompiler::compilePublishStmt(const ast::PublishStmt& stmt) {
    // 编译事件名称
    emitConst(stmt.get_event_name());
    
    // 编译载荷
    if (stmt.get_payload()) {
        compileExpression(*stmt.get_payload());
    } else {
        emitOp(bytecode::OpCode::PUSH);
        emitOp1(bytecode::OpCode::PUSH, 0);
    }
    
    emitOp(bytecode::OpCode::EXT);
}

void BytecodeCompiler::compileSubscribeStmt(const ast::SubscribeStmt& stmt) {
    // 编译事件处理器 (lambda)
    if (stmt.get_handler()) {
        compileExpression(*stmt.get_handler());
    }
    
    // 编译事件名称
    emitConst(stmt.get_event_name());
    
    emitOp(bytecode::OpCode::EXT);
}

// ========== 表达式编译 ==========

void BytecodeCompiler::compileExpression(const ast::Expression& expr) {
    switch (expr.get_kind()) {
        case ast::Expression::Kind::Literal:
            compileLiteralExpr(static_cast<const ast::LiteralExpr&>(expr));
            break;
        case ast::Expression::Kind::Identifier:
            compileIdentifierExpr(static_cast<const ast::IdentifierExpr&>(expr));
            break;
        case ast::Expression::Kind::Binary:
            compileBinaryExpr(static_cast<const ast::BinaryExpr&>(expr));
            break;
        case ast::Expression::Kind::Unary:
            compileUnaryExpr(static_cast<const ast::UnaryExpr&>(expr));
            break;
        case ast::Expression::Kind::Call:
            compileCallExpr(static_cast<const ast::CallExpr&>(expr));
            break;
        case ast::Expression::Kind::Index:
            compileIndexExpr(static_cast<const ast::IndexExpr&>(expr));
            break;
        case ast::Expression::Kind::Member:
            compileFieldExpr(static_cast<const ast::MemberExpr&>(expr));
            break;
        case ast::Expression::Kind::Array:
            compileArrayExpr(static_cast<const ast::ArrayExpr&>(expr));
            break;
        case ast::Expression::Kind::Tuple:
            compileTupleExpr(static_cast<const ast::TupleExpr&>(expr));
            break;
        case ast::Expression::Kind::Lambda:
            compileLambdaExpr(static_cast<const ast::LambdaExpr&>(expr));
            break;
        default:
            errorf("Unsupported expression kind: %d", (int)expr.get_kind());
    }
}

void BytecodeCompiler::compileLiteralExpr(const ast::LiteralExpr& expr) {
    const auto& value = expr.get_value();
    
    if (std::holds_alternative<int64_t>(value)) {
        emitConst((int)std::get<int64_t>(value));
    } else if (std::holds_alternative<double>(value)) {
        emitConst(std::get<double>(value));
    } else if (std::holds_alternative<std::string>(value)) {
        emitConst(std::get<std::string>(value));
    } else if (std::holds_alternative<bool>(value)) {
        emitConst(std::get<bool>(value) ? 1 : 0);
    } else if (std::holds_alternative<char>(value)) {
        emitConst((int)std::get<char>(value));
    } else {
        // NIL or unknown
        emitOp(bytecode::OpCode::PUSH);
        emitOp1(bytecode::OpCode::PUSH, 0);
    }
}

void BytecodeCompiler::compileIdentifierExpr(const ast::IdentifierExpr& expr) {
    int slot = resolveVariable(expr.get_name());
    if (slot >= 0) {
        emitLoadLocal(slot);
    } else {
        emitLoadGlobal(expr.get_name());
    }
}

void BytecodeCompiler::compileBinaryExpr(const ast::BinaryExpr& expr) {
    compileExpression(*expr.get_left());
    compileExpression(*expr.get_right());
    
    switch (expr.get_operator()) {
        case ast::BinaryOp::ADD:    emitOp(bytecode::OpCode::IADD); break;
        case ast::BinaryOp::SUB:    emitOp(bytecode::OpCode::ISUB); break;
        case ast::BinaryOp::MUL:    emitOp(bytecode::OpCode::IMUL); break;
        case ast::BinaryOp::DIV:    emitOp(bytecode::OpCode::IDIV); break;
        case ast::BinaryOp::MOD:    emitOp(bytecode::OpCode::IMOD); break;
        case ast::BinaryOp::FADD:   emitOp(bytecode::OpCode::FADD); break;
        case ast::BinaryOp::FSUB:   emitOp(bytecode::OpCode::FSUB); break;
        case ast::BinaryOp::FMUL:   emitOp(bytecode::OpCode::FMUL); break;
        case ast::BinaryOp::FDIV:   emitOp(bytecode::OpCode::FDIV); break;
        case ast::BinaryOp::FMOD:   emitOp(bytecode::OpCode::FMOD); break;
        case ast::BinaryOp::EQ:     emitOp(bytecode::OpCode::IEQ); break;
        case ast::BinaryOp::NEQ:    emitOp(bytecode::OpCode::INE); break;
        case ast::BinaryOp::LT:     emitOp(bytecode::OpCode::ILT); break;
        case ast::BinaryOp::LE:     emitOp(bytecode::OpCode::ILE); break;
        case ast::BinaryOp::GT:     emitOp(bytecode::OpCode::IGT); break;
        case ast::BinaryOp::GE:     emitOp(bytecode::OpCode::IGE); break;
        case ast::BinaryOp::AND:    emitOp(bytecode::OpCode::AND); break;
        case ast::BinaryOp::OR:     emitOp(bytecode::OpCode::OR); break;
        case ast::BinaryOp::BAND:   emitOp(bytecode::OpCode::BAND); break;
        case ast::BinaryOp::BOR:    emitOp(bytecode::OpCode::BOR); break;
        case ast::BinaryOp::BXOR:   emitOp(bytecode::OpCode::BXOR); break;
        case ast::BinaryOp::SHL:    emitOp(bytecode::OpCode::SHL); break;
        case ast::BinaryOp::SHR:    emitOp(bytecode::OpCode::SHR); break;
        default:
            errorf("Unknown binary operator: %d", (int)expr.get_operator());
    }
}

void BytecodeCompiler::compileUnaryExpr(const ast::UnaryExpr& expr) {
    compileExpression(*expr.get_operator()erand);
    
    switch (expr.get_operator()) {
        case ast::UnaryOp::NEG:
            emitOp(bytecode::OpCode::INEG);
            break;
        case ast::UnaryOp::FNEG:
            emitOp(bytecode::OpCode::FNEG);
            break;
        case ast::UnaryOp::NOT:
            emitOp(bytecode::OpCode::NOT);
            break;
        case ast::UnaryOp::BNOT:
            emitOp(bytecode::OpCode::BNOT);
            break;
    }
}

void BytecodeCompiler::compileCallExpr(const ast::CallExpr& expr) {
    // 编译参数 (从后往前，以便栈顺序正确)
    for (auto it = expr.get_arguments().rbegin(); it != expr.args.rend(); ++it) {
        compileExpression(**it);
    }
    
    // 编译函数表达式
    compileExpression(*expr.get_callee());
    
    // 调用指令
    emitOp1(bytecode::OpCode::CALL, expr.get_arguments().size());
}

void BytecodeCompiler::compileIndexExpr(const ast::IndexExpr& expr) {
    // 加载索引
    compileExpression(*expr.get_index());
    
    // 加载数组
    compileExpression(*expr.get_object());
    
    emitOp(bytecode::OpCode::LOAD_INDEX);
}

void BytecodeCompiler::compileFieldExpr(const ast::FieldExpr& expr) {
    // 加载对象
    compileExpression(*expr.get_object());
    
    // 字段名作为常量
    emitConst(expr.get_field());
    
    emitOp(bytecode::OpCode::LOAD_FIELD);
}

void BytecodeCompiler::compileArrayExpr(const ast::ArrayExpr& expr) {
    // 创建数组
    emitOp1(bytecode::OpCode::ALLOC_ARRAY, expr.get_elements().size());
    
    // 添加元素
    for (const auto& elem : expr.get_elements()) {
        compileExpression(*elem);
        emitOp(bytecode::OpCode::ARRAY_PUSH);
    }
}

void BytecodeCompiler::compileTupleExpr(const ast::TupleExpr& expr) {
    // 从后往前编译元素
    for (auto it = expr.get_elements().rbegin(); it != expr.get_elements().rend(); ++it) {
        compileExpression(**it);
    }
    
    emitOp1(bytecode::OpCode::CREATE_TUPLE, expr.get_elements().size());
}

void BytecodeCompiler::compileLambdaExpr(const ast::LambdaExpr& expr) {
    // 创建闭包
    emitOp(bytecode::OpCode::CLOSURE);
    int closureIdx = ctx_->currentFunction->instructions.size();
    
    // 创建新的编译上下文用于 lambda
    auto prevCtx = std::move(ctx_);
    ctx_ = std::make_unique<CompilationContext>();
    ctx_->currentFunction = std::make_shared<bytecode::Function>();
    ctx_->isClosure = true;
    ctx_->scopeDepth = prevCtx->scopeDepth + 1;
    
    // 添加参数槽位
    for (size_t i = 0; i < expr.get_params().size(); ++i) {
        ctx_->scopeStack.back()[expr.get_params()[i]] = i;
    }
    
    // 编译 lambda 体
    if (expr.get_body()) {
        compileBlockStmt(*expr.get_body());
    }
    
    // 默认返回 null
    if (ctx_->currentFunction->instructions.empty() ||
        ctx_->currentFunction->instructions.back().op != OpCode::RET) {
        emitOp(bytecode::OpCode::RET_NULL);
    }
    
    // 复制指令到外层函数
    auto lambdaFunc = ctx_->currentFunction;
    prevCtx->currentFunction->instructions.insert(
        prevCtx->currentFunction->instructions.end(),
        lambdaFunc->instructions.begin(),
        lambdaFunc->instructions.end()
    );
    
    // 恢复上下文
    ctx_ = std::move(prevCtx);
}

void BytecodeCompiler::compileTensorExpr(const ast::TensorExpr& expr) {
    // 张量创建
    emitOp(bytecode::OpCode::TENSOR_CREATE);
    
    // 编译形状
    for (const auto& dim : expr.get_shape()) {
        if (dim) {
            compileExpression(*dim);
        } else {
            emitConst(0); // 动态维度
        }
    }
    
    // 初始化数据
    if (!expr.get_data().empty()) {
        for (const auto& val : expr.get_data()) {
            if (val.type() == ast::NodeType::LITERAL) {
                const auto& lit = static_cast<const ast::LiteralExpr&>(*val);
                if (lit.litType == ast::LiteralType::INTEGER) {
                    emitConst(lit.intValue);
                } else if (lit.litType == ast::LiteralType::FLOAT) {
                    emitConst(lit.floatValue);
                }
            }
        }
    }
    
    emitOp(bytecode::OpCode::TENSOR_RESHAPE);
}

// ========== 作用域管理 ==========

void BytecodeCompiler::enterScope() {
    ctx_->scopeStack.emplace_back();
    ctx_->scopeDepth++;
}

void BytecodeCompiler::exitScope() {
    if (!ctx_->scopeStack.empty()) {
        // 恢复 upvalues
        for (const auto& uv : ctx_->upvalues) {
            // upvalue 关闭逻辑
        }
        ctx_->scopeStack.pop_back();
        ctx_->scopeDepth--;
    }
}

int BytecodeCompiler::resolveVariable(const std::string& name) {
    // 从内层作用域向外层查找
    for (auto it = ctx_->scopeStack.rbegin(); it != ctx_->scopeStack.rend(); ++it) {
        auto varIt = it->find(name);
        if (varIt != it->end()) {
            return varIt->second;
        }
    }
    return -1;
}

int BytecodeCompiler::allocateLocal(const std::string& name) {
    if (ctx_->scopeStack.empty()) {
        ctx_->scopeStack.emplace_back();
    }
    
    int slot = ctx_->scopeStack.back().size();
    ctx_->scopeStack.back()[name] = slot;
    return slot;
}

// ========== 指令生成辅助 ==========

void BytecodeCompiler::emitOp(OpCode op) {
    Instruction inst;
    inst.op = op;
    ctx_->currentFunction->instructions.push_back(inst);
}

void BytecodeCompiler::emitOp1(OpCode op, int operand) {
    Instruction inst;
    inst.op = op;
    inst.operand1 = operand;
    ctx_->currentFunction->instructions.push_back(inst);
}

void BytecodeCompiler::emitOp2(OpCode op, int operand1, int operand2) {
    Instruction inst;
    inst.op = op;
    inst.operand1 = operand1;
    inst.operand2 = operand2;
    ctx_->currentFunction->instructions.push_back(inst);
}

void BytecodeCompiler::emitOpF(OpCode op, double operand) {
    Instruction inst;
    inst.op = op;
    inst.floatVal = operand;
    ctx_->currentFunction->instructions.push_back(inst);
}

void BytecodeCompiler::emitOpS(OpCode op, const std::string& operand) {
    int constIdx = findOrAddString(operand);
    emitOp1(op, constIdx);
}

void BytecodeCompiler::emitJump(OpCode op) {
    Instruction inst;
    inst.op = op;
    ctx_->currentFunction->instructions.push_back(inst);
}

void BytecodeCompiler::patchJump(int jumpIdx, int targetIdx) {
    if (jumpIdx >= 0 && jumpIdx < (int)ctx_->currentFunction->instructions.size()) {
        ctx_->currentFunction->instructions[jumpIdx].operand1 = targetIdx;
    }
}

void BytecodeCompiler::emitLoadLocal(int slot) {
    if (slot == 0) {
        emitOp(bytecode::OpCode::LOAD_LOCAL_0);
    } else if (slot == 1) {
        emitOp(bytecode::OpCode::LOAD_LOCAL_1);
    } else {
        emitOp1(bytecode::OpCode::LOAD_LOCAL, slot);
    }
}

void BytecodeCompiler::emitStoreLocal(int slot) {
    if (slot == 0) {
        emitOp1(bytecode::OpCode::STORE_LOCAL, 0);
    } else if (slot == 1) {
        emitOp1(bytecode::OpCode::STORE_LOCAL, 1);
    } else {
        emitOp1(bytecode::OpCode::STORE_LOCAL, slot);
    }
}

void BytecodeCompiler::emitLoadGlobal(const std::string& name) {
    auto it = globalVars_.find(name);
    if (it != globalVars_.end()) {
        emitOp1(bytecode::OpCode::LOAD_GLOBAL, it->second);
    } else {
        // 动态全局变量
        emitOpS(OpCode::LOAD_GLOBAL, name);
    }
}

void BytecodeCompiler::emitStoreGlobal(const std::string& name) {
    auto it = globalVars_.find(name);
    if (it != globalVars_.end()) {
        emitOp1(bytecode::OpCode::STORE_GLOBAL, it->second);
    } else {
        // 动态全局变量
        emitOpS(OpCode::STORE_GLOBAL, name);
    }
}

void BytecodeCompiler::emitConst(int value) {
    int idx = addConstant(Value::fromInt(value));
    emitOp1(bytecode::OpCode::PUSH, idx);
}

void BytecodeCompiler::emitConst(double value) {
    int idx = addConstant(Value::fromDouble(value));
    emitOp1(bytecode::OpCode::PUSH, idx);
}

void BytecodeCompiler::emitConst(const std::string& value) {
    int idx = findOrAddString(value);
    emitOp1(bytecode::OpCode::PUSH, idx);
}

// ========== 类型相关 ==========

std::string BytecodeCompiler::getTypeName(const ast::TypeExpr& typeExpr) {
    if (typeExpr.baseType == "int" || typeExpr.baseType == "i8" || 
        typeExpr.baseType == "i16" || typeExpr.baseType == "i32" || 
        typeExpr.baseType == "i64") {
        return "int";
    } else if (typeExpr.baseType == "float" || typeExpr.baseType == "f32") {
        return "float";
    } else if (typeExpr.baseType == "double" || typeExpr.baseType == "f64") {
        return "double";
    } else if (typeExpr.baseType == "bool") {
        return "bool";
    } else if (typeExpr.baseType == "string") {
        return "string";
    }
    return typeExpr.baseType;
}

// ========== 错误处理 ==========

void BytecodeCompiler::error(const std::string& msg) {
    lastError_ = msg;
    throw std::runtime_error(msg);
}

void BytecodeCompiler::errorf(const char* fmt, ...) {
    char buf[256];
    va_list args;
    va_start(args, fmt);
    vsnprintf(buf, sizeof(buf), fmt, args);
    va_end(args);
    error(buf);
}

// ========== 调试信息 ==========

void BytecodeCompiler::addDebugInfo(const std::string& name, int line) {
    if (debugInfo_) {
        DebugInfo info;
        info.name = name;
        info.line = line;
        ctx_->currentFunction->debugInfo.push_back(info);
    }
}

// ========== 常量池管理 ==========

int BytecodeCompiler::addConstant(Value value) {
    // 查找现有常量
    for (size_t i = 0; i < module_->constants.size(); ++i) {
        if (module_->constants[i] == value) {
            return i;
        }
    }
    
    int idx = module_->constants.size();
    module_->constants.push_back(value);
    return idx;
}

int BytecodeCompiler::findOrAddString(const std::string& str) {
    return addConstant(Value::fromString(str));
}

} // namespace claw
