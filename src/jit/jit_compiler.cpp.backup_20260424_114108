}

void OptimizingJITCompiler::emit_prologue(uint8_t*& code_ptr, size_t local_count) {
    // x86-64 函数序言 (优化版本)
    // push rbp
    // mov rbp, rsp
    // sub rsp, local_size
    uint8_t* code = code_ptr;
    
    // push rbp
    code[0] = 0x55;
    // mov rbp, rsp  
    code[1] = 0x48;
    code[2] = 0x89;
    code[3] = 0xe5;
    
    // 分配局部变量空间
    if (local_count > 0) {
        size_t stack_size = local_count * 8;
        if (stack_size <= 127) {
            code[4] = 0x48;
            code[5] = 0x83;
            code[6] = 0xec;
            code[7] = static_cast<uint8_t>(stack_size);
            code_ptr = &code[8];
        } else {
            code[4] = 0x48;
            code[5] = 0x81;
            code[6] = 0xec;
            *reinterpret_cast<uint32_t*>(&code[7]) = static_cast<uint32_t>(stack_size);
            code_ptr = &code[11];
        }
    } else {
        code_ptr = &code[4];
    }
}

void OptimizingJITCompiler::emit_epilogue(uint8_t*& code_ptr) {
    // x86-64 函数结尾
    uint8_t* code = code_ptr;
    code[0] = 0x5d; // pop rbp
    code[1] = 0xc3; // ret
    code_ptr = &code[2];
}

